{
  "uid": "athena-trading",
  "title": "Athena — Trading Overview",
  "description": "Real-time view of the matching engine: orders, trades, latency, ring buffer health",
  "tags": ["athena", "trading", "matching-engine"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Orders / s",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5000 }, { "color": "red", "value": 10000 }] }, "unit": "reqps" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(athena_orders_accepted_total[1m]))", "legendFormat": "orders/s" }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Trades / s",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] }, "unit": "reqps" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(athena_trades_executed_total[1m]))", "legendFormat": "trades/s" }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Matching p99 latency",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.0001 }, { "color": "red", "value": 0.001 }] }, "unit": "s" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(athena_matching_book_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p99" }]
    },

    {
      "id": 4,
      "type": "gauge",
      "title": "Ring buffer utilization",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizValue": 0, "maxVizValue": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 0.8 }] }, "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - (athena_disruptor_buffer_remaining / athena_disruptor_buffer_capacity)", "legendFormat": "utilization" }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "REST p99 (POST /orders)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.003 }, { "color": "red", "value": 0.005 }] }, "unit": "s" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/orders\", method=\"POST\"}[1m])) by (le))", "legendFormat": "p99" }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Error rate",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.001 }] }, "unit": "percentunit" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/.*\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/.*\"}[5m]))", "legendFormat": "error %" }]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Orders & Trades per second (by symbol)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(athena_orders_accepted_total[1m])) by (symbol)", "legendFormat": "orders {{symbol}}" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(athena_trades_executed_total[1m])) by (symbol)", "legendFormat": "trades {{symbol}}" }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Matching latency percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(athena_matching_book_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(athena_matching_book_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p95" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(athena_matching_book_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p99" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.999, sum(rate(athena_matching_book_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p99.9" }
      ]
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "Ring buffer capacity over time",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "athena_disruptor_buffer_remaining", "legendFormat": "remaining" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "athena_disruptor_buffer_capacity", "legendFormat": "total" }
      ]
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "JVM heap usage",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "heap used" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "jvm_memory_max_bytes{area=\"heap\"}", "legendFormat": "heap max" }
      ]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "HTTP throughput by endpoint",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/.*\"}[1m])) by (uri, method)", "legendFormat": "{{method}} {{uri}}" }
      ]
    }

  ]
}
