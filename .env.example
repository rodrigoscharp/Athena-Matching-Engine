# ─────────────────────────────────────────────────────────────────────────────
# Athena Matching Engine — environment variables
#
# Copy this file to .env and fill in the values for your environment.
# The application uses ${VAR:default} syntax — every variable below has a
# safe default for local development. In production, override all of them.
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=local
SERVER_PORT=8080
GRPC_PORT=9090
MANAGEMENT_PORT=8080
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_ATHENA=DEBUG

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433   # override: 5432 may be occupied by another local Postgres
DB_NAME=athena
DB_USER=athena
DB_PASSWORD=athena
DB_POOL_SIZE=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka / Schema Registry ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_CONSUMER_GROUP=athena-engine

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
TRACING_SAMPLING_PROBABILITY=1.0
